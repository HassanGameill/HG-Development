<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Order Confirmation</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f1f5f9;
      font-family: Arial, Helvetica, sans-serif;
      color: #1f2937;
    }

    .email-wrapper {
      width: 100%;
      padding: 30px 0;
    }

    .email-container {
      max-width: 600px;
      margin: auto;
      background-color: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 20px rgba(0,0,0,0.06);
    }

    .email-header {
      background: linear-gradient(135deg, #2563eb, #1e40af);
      padding: 25px;
      text-align: center;
      color: #ffffff;
    }

    .email-header h1 {
      margin: 0;
      font-size: 24px;
    }

    .email-body {
      padding: 30px;
    }

    .email-body h2 {
      margin-top: 0;
      font-size: 20px;
    }

    .email-body p {
      font-size: 14px;
      line-height: 1.6;
      margin: 10px 0;
    }

    .order-card {
      margin: 25px 0;
      background-color: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 20px;
    }

    .order-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
      font-size: 14px;
    }

    .price {
      font-size: 18px;
      font-weight: bold;
      color: #16a34a;
      text-align: right;
      margin-top: 15px;
    }

    .cta {
      margin-top: 25px;
      text-align: center;
    }

    .cta a {
      display: inline-block;
      background-color: #2563eb;
      color: #ffffff;
      padding: 12px 22px;
      border-radius: 6px;
      text-decoration: none;
      font-size: 14px;
      font-weight: bold;
    }

    .email-footer {
      background-color: #f8fafc;
      text-align: center;
      padding: 15px;
      font-size: 12px;
      color: #6b7280;
    }

    @media (max-width: 600px) {
      .email-body {
        padding: 20px;
      }
    }
  </style>
</head>

<body>
  <div class="email-wrapper">
    <div class="email-container">

      <!-- Header -->
      <div class="email-header">
        <h1>Order Confirmed 🎉</h1>
      </div>

      <!-- Body -->
      <div class="email-body">

        <p>
          Thank you for your purchase! Your order has been successfully completed
          and you now have access to your course.
        </p>

        <div class="order-card">
          <div class="order-row">
            <span><strong>Order ID</strong></span>
            <span>#<%= order._id %></span>
          </div>

          <div class="order-row">
            <span><strong>Course Name</strong></span>
            <span><%= order.name %></span>
          </div>

          

          <div class="order-row">
            <span><strong>Date</strong></span>
            <span><%= order.date %></span>
          </div>

          <div class="price">
            Total: $<%= order.price %>
          </div>
        </div>

       

        <p style="margin-top: 25px;">
          If you have any questions, just reply to this email — we’re happy to help.
        </p>

        <p>
          Best regards,<br />
          <strong>Your Platform Team</strong>
        </p>
      </div>

      <!-- Footer -->
      <div class="email-footer">
        © <%= new Date().getFullYear() %> Your Platform. All rights reserved.
      </div>

    </div>
  </div>
</body>
</html>
