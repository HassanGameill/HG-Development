<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Reply Notification</title>
  </head>

  <body style="font-family: Arial, Helvetica, sans-serif; line-height: 1.6;">
    <h1>Hello <%= name %>,</h1>

    <p>
      A new reply has been added to your question on the following video:
    </p>

    <p>
      <strong>English Title:</strong> <%= titleEn %>
    </p>

    <p>
      <strong>Arabic Title:</strong> <%= titleAr %>
    </p>

    <p>
      Please log in to our website to view the reply.
    </p>

    <p>
      Thank you for being part of our community.
    </p>

    <p>
      Best regards,<br />
      <strong>The Support Team</strong>
    </p>
  </body>
</html>
